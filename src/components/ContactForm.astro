---
// ContactForm — preventivo request form
// ⚠️ NO "24h risposta" — regola brand memory.md 12 mag 2026
interface Props {
  preselectLinea?: 'standard' | 'custom' | 'unsure' | '';
  variant?: 'dark' | 'navy';
  id?: string;
  showHeader?: boolean;
}
const { preselectLinea = '', variant = 'dark', id = 'preventivo', showHeader = true } = Astro.props;

const bgClass = variant === 'navy' ? 'bg-navy' : 'bg-ink';

// Anti-spam (iter-10): Turnstile site key pubblica per il widget
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---

<section id={id} class={`${bgClass} text-cream py-24 md:py-32 relative overflow-hidden`}>
  <div class="absolute -bottom-32 -left-20 w-[400px] h-[400px] rounded-full bg-orange/15 blur-3xl pointer-events-none"></div>
  <div class="max-w-5xl mx-auto px-6 relative">
    {showHeader && (
      <>
        <div class="flex items-center gap-3 mb-6">
          <span class="eyebrow text-orange">
            {preselectLinea === 'custom' ? 'avete in mente qualcosa di particolare?' : 'pronti a partire?'}
          </span>
        </div>
        <h2 class="font-display-tight text-5xl md:text-7xl leading-[0.95] mb-6 max-w-3xl" set:html={preselectLinea === 'custom' ? 'Raccontatelo qui.' : 'Raccontateci<br>cosa vi serve.'}></h2>
        <p class="text-xl text-cream/80 mb-12 max-w-2xl">
          Bozza visiva gratuita. Senza impegno. <span class="text-orange font-bold">Senza costi.</span>
        </p>
      </>
    )}
    <form
      id="form-preventivo"
      action="/api/lead"
      method="POST"
      class="grid grid-cols-1 md:grid-cols-2 gap-5"
      novalidate
    >
      <!-- Anti-spam L1: honeypot — non rimuovere -->
      <div aria-hidden="true" style="position:absolute; left:-9999px; top:-9999px; height:0; width:0; overflow:hidden;">
        <label for="website-pv">Leave this field empty</label>
        <input type="text" name="website" id="website-pv" tabindex="-1" autocomplete="off" />
      </div>
      <!-- Anti-spam L3: timestamp di caricamento (sovrascritto lato client) -->
      <input type="hidden" name="_form_loaded" value="0" />
      <input
        type="text"
        name="nome"
        placeholder="Nome e Cognome*"
        required
        class="bg-cream/5 border-2 border-cream/20 rounded-xl px-5 py-4 text-cream placeholder:text-cream/40 focus:border-orange focus:outline-none transition"
      />
      <input
        type="text"
        name="azienda"
        placeholder="Azienda (opzionale)"
        class="bg-cream/5 border-2 border-cream/20 rounded-xl px-5 py-4 text-cream placeholder:text-cream/40 focus:border-orange focus:outline-none transition"
      />
      <input
        type="email"
        name="email"
        placeholder="Email aziendale*"
        required
        class="bg-cream/5 border-2 border-cream/20 rounded-xl px-5 py-4 text-cream placeholder:text-cream/40 focus:border-orange focus:outline-none transition"
      />
      <input
        type="tel"
        name="telefono"
        placeholder="Telefono*"
        required
        class="bg-cream/5 border-2 border-cream/20 rounded-xl px-5 py-4 text-cream placeholder:text-cream/40 focus:border-orange focus:outline-none transition"
      />
      <textarea
        name="messaggio"
        rows={preselectLinea === 'custom' ? 5 : 4}
        placeholder={preselectLinea === 'custom'
          ? 'Cosa avete in mente?* Es. forma, Pantone, materiale, quantità, deadline.'
          : 'Cosa dovete realizzare?* Es. 100 t-shirt, 500 power bank, una collezione su misura.'}
        required
        class="md:col-span-2 bg-cream/5 border-2 border-cream/20 rounded-xl px-5 py-4 text-cream placeholder:text-cream/40 focus:border-orange focus:outline-none transition"
      ></textarea>
      <label class="md:col-span-2 flex items-start gap-3 text-sm text-cream/70">
        <input type="checkbox" name="privacy" required class="mt-1 accent-orange" />
        <span>Ho letto e accetto la <a href="/privacy" class="underline hover:text-orange transition">Privacy Policy</a>.</span>
      </label>
      <!-- Anti-spam L2: Cloudflare Turnstile -->
      <div class="cf-turnstile md:col-span-2" data-sitekey={TURNSTILE_SITE_KEY} data-theme="dark" data-size="flexible"></div>
      <button
        type="submit"
        class="btn-orange md:col-span-2 bg-orange text-cream py-5 px-8 text-base font-bold tracking-wide rounded-full hover:bg-cream hover:text-ink transition"
      >
        {preselectLinea === 'custom' ? 'Richiedi Bozza Custom →' : 'Richiedi Preventivo e Bozza →'}
      </button>
    </form>
    <p class="text-sm text-cream/60 mt-6">
      Risposte <strong class="text-cream">rapide</strong>. Nessun obbligo di acquisto.
    </p>
    <p class="text-sm text-cream/60 mt-2">
      Oppure <a href="https://wa.me/393451448645?text=Ciao%202promo%2C%20vorrei%20un%20preventivo" target="_blank" rel="noopener" class="text-orange font-bold hover:text-cream transition">scriveteci direttamente su WhatsApp →</a>
    </p>
  </div>
</section>

<!-- Anti-spam L2: Turnstile loader -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline>
  (function() {
    var form = document.getElementById('form-preventivo');
    if (!form) return;
    // L3: timestamp fresco al mount client (lo SSR/static è stale)
    var ts = form.querySelector('input[name="_form_loaded"]');
    if (ts) ts.value = Date.now();
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.textContent = 'Invio in corso…';
        btn.disabled = true;
      }
      try {
        var data = new FormData(form);
        var resp = await fetch('/api/lead', {
          method: 'POST',
          body: data,
        });
        if (resp.ok) {
          window.location.href = '/grazie';
        } else {
          throw new Error('Errore ' + resp.status);
        }
      } catch(err) {
        if (btn) {
          btn.textContent = 'Riprova →';
          btn.disabled = false;
        }
        // Turnstile è single-use: reset per consentire un nuovo tentativo
        if (window.turnstile) { try { window.turnstile.reset(); } catch(_) {} }
        alert('Qualcosa è andato storto. Riprova o scrivici a info@2promo.it');
      }
    });
  })();
</script>
