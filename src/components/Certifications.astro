---
// Certifications — sezione sostenibilità con loghi certificazione
const certs = [
  { src: '/certifications/oeko-tex.png',    alt: 'OEKO-TEX Standard 100' },
  { src: '/certifications/grs.png',         alt: 'Global Recycle Standard (GRS)' },
  { src: '/certifications/fairtrade.png',   alt: 'Fairtrade' },
  { src: '/certifications/eu-ecolabel.png', alt: 'EU Ecolabel' },
  { src: '/certifications/amfori.png',      alt: 'Amfori' },
  { src: '/certifications/sedex.png',       alt: 'Sedex' },
  { src: '/certifications/ocs-organic.png', alt: 'Organic Content Standard (OCS)' },
  { src: '/certifications/rcs-recycled.png',alt: 'Recycled Claim Standard (RCS)' },
  { src: '/certifications/reach.png',       alt: 'REACH Compliance' },
  { src: '/certifications/bsci.png',        alt: 'BSCI' },
];
---

<section id="certificazioni" class="bg-cream py-20 md:py-24 border-t border-ink/10">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="eyebrow text-ink/70">qualità certificata</span>
    </div>
    <h2 class="font-display-tight text-5xl md:text-6xl text-ink leading-[0.95] mb-4" data-reveal>
      Sostenibili<br>sul serio.
    </h2>
    <p class="text-ink/70 text-lg max-w-2xl mb-12" data-reveal>
      RPET, bambù, cotone bio. Lavoriamo solo con materiali certificati e ne forniamo prova su richiesta per ogni articolo del catalogo.
    </p>
    <div class="grid grid-cols-3 md:grid-cols-5 gap-3 md:gap-4 lg:gap-6" data-reveal>
      {certs.map(c => (
        <div class="bg-white rounded-xl p-4 md:p-5 flex items-center justify-center aspect-square shadow-sm">
          <img
            src={c.src}
            alt={c.alt}
            class="max-h-full max-w-full object-contain filter grayscale opacity-70 hover:grayscale-0 hover:opacity-100 transition duration-300"
            width="80"
            height="80"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  </div>
</section>
