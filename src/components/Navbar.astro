---
interface Props {
  activeRoute?: 'home' | 'custom' | 'catalogo' | 'preventivo' | 'other';
}
const { activeRoute = 'home' } = Astro.props;
---
<nav id="nav" class="sticky top-0 z-40 transition-all duration-300 bg-cream/60">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between gap-4">
    <a href="/" style="text-decoration:none;">
      <img src="/brand/logo.webp" alt="2promo.it — gadget aziendali personalizzati" class="h-10 md:h-12 w-auto" width="600" height="218" fetchpriority="high" />
    </a>
    <div class="hidden md:flex items-center gap-7 text-sm font-bold">
      <a href="/" class={`nav-link hover:text-orange transition ${activeRoute === 'home' ? 'active' : ''}`}>Home</a>
      <a href="/custom" class={`nav-link hover:text-orange transition ${activeRoute === 'custom' ? 'active' : ''}`}>Custom</a>
      <a href="/catalogo" class={`nav-link hover:text-orange transition ${activeRoute === 'catalogo' ? 'active' : ''}`}>Catalogo</a>
      <a href="/preventivo" class={`nav-link hover:text-orange transition ${activeRoute === 'preventivo' ? 'active' : ''}`}>Preventivo</a>
    </div>
    <div class="flex items-center gap-4">
      <a
        href="https://wa.me/393451448645?text=Ciao%202promo%2C%20vorrei%20un%20preventivo"
        target="_blank"
        rel="noopener"
        class="hidden md:inline-flex items-center gap-2 text-sm font-bold text-ink hover:text-orange transition"
        aria-label="Scrivici su WhatsApp"
        style="text-decoration:none;"
      >
        <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4 7.94 7.94 0 0 0 5.1 16.16L4 20.66l4.66-1.22a7.94 7.94 0 0 0 3.79.97h.01a7.94 7.94 0 0 0 7.94-7.93 7.88 7.88 0 0 0-2.8-6.16zM12.05 18.95h-.01a6.58 6.58 0 0 1-3.36-.92l-.24-.14-2.77.72.74-2.7-.16-.25a6.6 6.6 0 1 1 12.21-3.5 6.61 6.61 0 0 1-6.41 6.79zm3.62-4.94c-.2-.1-1.18-.58-1.36-.65-.18-.07-.31-.1-.45.1-.13.2-.51.65-.62.78-.11.13-.23.15-.43.05a5.43 5.43 0 0 1-2.71-2.37c-.2-.35.2-.32.59-1.08.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34h-.39c-.13 0-.35.05-.53.25-.18.2-.7.68-.7 1.66 0 .98.71 1.92.81 2.05.1.13 1.4 2.13 3.39 2.99 1.99.86 1.99.57 2.35.53.36-.04 1.18-.48 1.34-.95.17-.46.17-.86.12-.95-.05-.08-.18-.13-.38-.23z"/></svg>
        <span>WhatsApp</span>
      </a>
      <a
        href="/preventivo"
        class="btn-orange bg-orange text-cream px-5 py-3 text-sm font-bold tracking-wide rounded-full hover:bg-ink transition hidden sm:inline-block"
        style="text-decoration:none;"
      >
        Richiedi Preventivo →
      </a>
    </div>
  </div>
</nav>
