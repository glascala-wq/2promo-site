---
interface Props {
  variant?: 'marquee' | 'grid';
}
const { variant = 'marquee' } = Astro.props;

const logos = [
  { src: '/clients/red-bull.png',             alt: 'Red Bull' },
  { src: '/clients/binance.png',              alt: 'Binance' },
  { src: '/clients/wonderbox.png',            alt: 'Wonderbox' },
  { src: '/clients/mediaworld.png',           alt: 'MediaWorld' },
  { src: '/clients/monge.png',                alt: 'Monge' },
  { src: '/clients/rds.png',                  alt: 'RDS' },
  { src: '/clients/radio-italia.png',         alt: 'Radio Italia' },
  { src: '/clients/edilizia-acrobatica.png',  alt: 'EdiliziaAcrobatica' },
  { src: '/clients/prato-nevoso.png',         alt: 'Prato Nevoso' },
  { src: '/clients/afry.png',                 alt: 'AFRY' },
  { src: '/clients/sea-milano.png',           alt: 'SEA Milano' },
  { src: '/clients/capitaneria-di-porto.png', alt: 'Capitaneria di Porto' },
];
---

{variant === 'marquee' ? (
  <section class="bg-ink text-cream py-10 overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 mb-6 flex items-center gap-3">
      <span class="w-8 h-px bg-cream/40"></span>
      <span class="eyebrow text-cream/60">si fidano di noi</span>
    </div>
    <div class="relative">
      <div class="flex gap-16 marquee-track items-center">
        <!-- Set 1 -->
        <div class="flex gap-16 items-center shrink-0">
          {logos.map(l => (
            <img src={l.src} alt={l.alt} class="client-logo" width="200" height="60" />
          ))}
        </div>
        <!-- Set 2 — duplicate for seamless loop -->
        <div class="flex gap-16 items-center shrink-0" aria-hidden="true">
          {logos.map(l => (
            <img src={l.src} alt="" class="client-logo" width="200" height="60" loading="lazy" />
          ))}
        </div>
      </div>
    </div>
  </section>
) : (
  <section class="bg-cream py-16">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-10">
        <span class="w-8 h-px bg-ink"></span>
        <span class="eyebrow text-ink/70">si fidano di noi</span>
      </div>
      <div class="flex flex-wrap gap-x-12 gap-y-8 items-center">
        {logos.map(l => (
          <img src={l.src} alt={l.alt} class="client-logo-grid" width="120" height="40" loading="lazy" />
        ))}
      </div>
    </div>
  </section>
)}
