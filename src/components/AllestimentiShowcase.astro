---
// AllestimentiShowcase — home teaser for the allestimenti line, same cat-card
// treatment as /allestimenti.astro, reusing the same product photos.
const categories = [
  { name: 'Fondali', image: '/allestimenti/products/fondale.webp' },
  { name: 'Totem', image: '/allestimenti/products/totem.webp' },
  { name: 'Banchetti', image: '/allestimenti/products/banchetto.webp' },
  { name: 'Segnaletica', image: '/allestimenti/products/segnaletica.webp' },
  { name: 'Gazebo', image: '/allestimenti/products/gazebo.webp' },
  { name: 'Bandiere', image: '/allestimenti/products/bandiere.webp' },
  { name: 'Roll-up e banner', image: '/allestimenti/products/rollup.webp' },
];
---

<section class="bg-cream py-20 md:py-24 border-y border-ink/10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-end justify-between flex-wrap gap-6 mb-10">
      <div>
        <div class="flex items-center gap-3 mb-5" data-reveal>
          <span class="eyebrow text-orange">materiale per farsi notare ovunque</span>
        </div>
        <h2 class="font-display-tight text-5xl md:text-7xl text-ink leading-[0.9]" data-reveal>
          Anche il vostro spazio<br>ha un reparto.
        </h2>
      </div>
      <p class="text-ink/70 text-lg max-w-md" data-reveal>
        Fondali, totem, banchetti, gazebo, bandiere, roll-up: lo stesso sistema modulare e la stessa attenzione che mettiamo nei gadget, per far risaltare il vostro logo in ufficio, in negozio, a un evento aziendale o in fiera.
      </p>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5 mb-10">
      {categories.map((c) => (
        <div class="cat-card relative rounded-3xl overflow-hidden aspect-square" data-reveal>
          <div class="relative w-full h-full bg-gray-light">
            <img src={c.image} alt={c.name} class="w-full h-full object-cover" width="400" height="400" loading="lazy" />
            <p class="absolute bottom-0 left-0 right-0 p-4 font-display text-sm text-cream bg-gradient-to-t from-ink/80 to-transparent pt-8">{c.name}</p>
          </div>
        </div>
      ))}
    </div>
    <a
      href="/allestimenti"
      class="border-2 border-ink text-ink px-7 py-4 text-sm font-bold tracking-wide rounded-full hover:bg-ink hover:text-cream transition inline-block"
      style="text-decoration:none;"
    >
      Scopri gli allestimenti →
    </a>
  </div>
</section>
