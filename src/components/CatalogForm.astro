---
// CatalogForm — email-only form to receive PDF catalog
// Anti-spam (iter-10): Turnstile site key pubblica per il widget
const TURNSTILE_SITE_KEY = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY;
---
<section class="bg-cream py-24 md:py-28">
  <div class="max-w-3xl mx-auto px-6 text-center">
    <div class="flex items-center justify-center gap-3 mb-6">
      <span class="eyebrow text-ink/70">preferite sfogliare offline?</span>
    </div>
    <h2 class="font-display-tight text-5xl md:text-6xl text-ink leading-[0.95] mb-6">
      Il PDF, in email.<br>Subito.
    </h2>
    <p class="text-lg text-ink/70 mb-10 max-w-xl mx-auto">
      Vi spediamo la nostra selezione gadget aziendali in PDF (484 pagine), pronta da condividere col team o stampare. Vi arriva entro 2 minuti.
    </p>
    <form
      id="form-catalogo"
      action="/api/catalogo"
      method="POST"
      class="flex flex-col gap-4 max-w-lg mx-auto"
      novalidate
    >
      <!-- Anti-spam L1: honeypot — non rimuovere -->
      <div aria-hidden="true" style="position:absolute; left:-9999px; top:-9999px; height:0; width:0; overflow:hidden;">
        <label for="website-cat">Leave this field empty</label>
        <input type="text" name="website" id="website-cat" tabindex="-1" autocomplete="off" />
      </div>
      <!-- Anti-spam L3: timestamp di caricamento (sovrascritto lato client) -->
      <input type="hidden" name="_form_loaded" value="0" />
      <div class="flex flex-col sm:flex-row gap-3 w-full">
        <input
          type="email"
          name="email"
          placeholder="email@azienda.com"
          required
          class="flex-1 bg-cream border-2 border-ink/20 rounded-full px-6 py-4 text-ink placeholder:text-ink/40 focus:border-orange focus:outline-none transition"
        />
        <button
          type="submit"
          class="btn-orange bg-orange text-cream px-7 py-4 text-sm font-bold tracking-wide rounded-full hover:bg-ink transition whitespace-nowrap"
        >
          Inviami il PDF →
        </button>
      </div>
      <!-- Anti-spam L2: Cloudflare Turnstile (dentro il form → token in FormData) -->
      <div class="cf-turnstile flex justify-center" data-sitekey={TURNSTILE_SITE_KEY} data-theme="light" data-size="flexible"></div>
    </form>
    <p class="text-sm text-ink/70 mt-4">Nessuno spam. Solo il PDF + qualche idea utile ogni tanto.</p>
  </div>
</section>

<!-- Anti-spam L2: Turnstile loader -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script is:inline>
  (function() {
    var form = document.getElementById('form-catalogo');
    if (!form) return;
    // L3: timestamp fresco al mount client (lo SSR/static è stale)
    var ts = form.querySelector('input[name="_form_loaded"]');
    if (ts) ts.value = Date.now();
    form.addEventListener('submit', async function(e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      var input = form.querySelector('input[type="email"]');
      if (btn) {
        btn.textContent = 'Invio…';
        btn.disabled = true;
      }
      try {
        var data = new FormData(form);
        var resp = await fetch('/api/catalogo', {
          method: 'POST',
          body: data,
        });
        if (resp.ok) {
          if (input) input.value = '';
          if (btn) { btn.textContent = 'Inviato ✓'; }
          if (window.turnstile) { try { window.turnstile.reset(); } catch(_) {} }
          setTimeout(function() {
            if (btn) { btn.textContent = 'Inviami il PDF →'; btn.disabled = false; }
          }, 3000);
        } else {
          throw new Error('Errore ' + resp.status);
        }
      } catch(err) {
        if (btn) { btn.textContent = 'Riprova →'; btn.disabled = false; }
        // Turnstile è single-use: reset per consentire un nuovo tentativo
        if (window.turnstile) { try { window.turnstile.reset(); } catch(_) {} }
        alert('Qualcosa è andato storto. Riprova o scrivici a info@2promo.it');
      }
    });
  })();
</script>
