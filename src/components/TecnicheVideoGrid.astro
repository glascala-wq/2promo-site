---
import { TECNICHE_VIDEOS } from '../data/tecniche-videos';

interface Props {
  eyebrow?: string;
  heading?: string;
}

const { eyebrow = 'la rubrica in video', heading = 'Tecniche di Stampa — come diamo vita ai tuoi loghi' } = Astro.props;

const uploadDate = '2026-05-12';

// ItemList di VideoObject (GEO/SEO) — auto-generato dagli stessi dati della griglia, niente duplicazione.
const videoJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: TECNICHE_VIDEOS.map((v) => ({
    '@type': 'ListItem',
    position: v.episodio,
    item: {
      '@type': 'VideoObject',
      name: `Tecniche di Stampa — Ep. ${String(v.episodio).padStart(2, '0')}: ${v.titolo}`,
      description: v.descrizione,
      thumbnailUrl: `https://www.2promo.it${v.poster}`,
      contentUrl: `https://www.2promo.it${v.video}`,
      uploadDate,
      duration: `PT${v.durataSecondi}S`,
    },
  })),
}).replace(/</g, '\\u003c');
---

<section id="tecniche-di-stampa-video" class="bg-cream pb-16 md:pb-20">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="eyebrow text-orange">{eyebrow}</span>
    </div>
    <h2 class="font-display-tight text-4xl md:text-5xl leading-[0.95] text-ink mb-12 max-w-3xl" data-reveal set:html={heading} />

    <div class="grid grid-cols-2 md:grid-cols-3 gap-5 md:gap-8">
      {TECNICHE_VIDEOS.map((v) => (
        <div class="tecnica-card group" data-reveal>
          <div class="relative aspect-square rounded-2xl overflow-hidden bg-ink">
            <video
              class="tecnica-video w-full h-full object-cover"
              muted
              playsinline
              loop
              preload="none"
              poster={v.poster}
              data-src={v.video}
              aria-hidden="true"
              tabindex="-1"
            >
              <source data-src={v.video} type="video/mp4" />
            </video>
            <button
              type="button"
              class="tecnica-expand absolute inset-0 flex items-center justify-center bg-ink/0 group-hover:bg-ink/20 transition"
              aria-label={`Ingrandisci il video: ${v.titolo}`}
              data-video={v.video}
              data-poster={v.poster}
              data-title={v.titolo}
              data-desc={v.descrizione}
            >
              <span class="tecnica-expand-icon w-12 h-12 rounded-full bg-cream/90 flex items-center justify-center shadow-md opacity-0 group-hover:opacity-100 group-focus-within:opacity-100 transition">
                <svg class="w-5 h-5 text-ink" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M9 3H5a2 2 0 0 0-2 2v4M15 3h4a2 2 0 0 1 2 2v4M9 21H5a2 2 0 0 1-2-2v-4M15 21h4a2 2 0 0 0 2-2v-4"/>
                </svg>
              </span>
            </button>
            <span class="absolute top-3 left-3 eyebrow text-cream bg-ink/60 rounded-full px-3 py-1 text-[0.65rem] pointer-events-none">
              Ep. {String(v.episodio).padStart(2, '0')}
            </span>
          </div>
          <h3 class="font-display-tight text-xl text-ink mt-4 mb-1">{v.titolo}</h3>
          <p class="text-sm text-ink/70 leading-relaxed">{v.descrizione}</p>
        </div>
      ))}
    </div>

    <div class="border-t border-ink/10 mt-14 pt-10 text-center" data-reveal>
      <p class="font-display-tight text-2xl md:text-3xl text-ink leading-tight mb-6 max-w-xl mx-auto">
        Vuoi vedere la tecnica giusta applicata al tuo logo?
      </p>
      <a
        href="/preventivo"
        class="btn-orange bg-orange text-cream px-8 py-4 rounded-full font-bold tracking-wide hover:bg-ink transition inline-block"
        style="text-decoration:none;"
      >
        Richiedi un preventivo →
      </a>
    </div>
  </div>
</section>

<div
  id="tecnica-lightbox"
  class="hidden fixed inset-0 z-50 items-center justify-center bg-ink/90 p-4 md:p-10"
  role="dialog"
  aria-modal="true"
  aria-labelledby="tecnica-lightbox-title"
>
  <button
    type="button"
    id="tecnica-lightbox-close"
    class="absolute top-4 right-4 md:top-8 md:right-8 w-11 h-11 rounded-full bg-cream/90 flex items-center justify-center hover:bg-orange transition"
    aria-label="Chiudi video"
  >
    <svg viewBox="0 0 24 24" class="w-5 h-5 text-ink" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18"/></svg>
  </button>
  <div class="max-w-xl w-full">
    <div class="relative aspect-square rounded-2xl overflow-hidden bg-ink">
      <video id="tecnica-lightbox-video" class="w-full h-full object-cover cursor-pointer" muted playsinline loop preload="none"></video>
    </div>
    <div class="mt-5 text-center">
      <h3 id="tecnica-lightbox-title" class="font-display-tight text-2xl text-cream mb-1"></h3>
      <p id="tecnica-lightbox-desc" class="text-cream/70 text-sm max-w-md mx-auto"></p>
    </div>
  </div>
</div>

<script type="application/ld+json" set:html={videoJsonLd} />

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var cards = document.querySelectorAll('.tecnica-card');
    var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function loadSource(video) {
      if (video.dataset.loaded) return;
      var source = video.querySelector('source');
      if (source && source.dataset.src) source.src = source.dataset.src;
      if (video.dataset.src) video.src = video.dataset.src;
      video.load();
      video.dataset.loaded = 'true';
    }

    if (!reduceMotion && typeof IntersectionObserver !== 'undefined') {
      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            var card = entry.target;
            var video = card.querySelector('.tecnica-video');
            if (!video) return;
            if (entry.isIntersecting) {
              loadSource(video);
              video.play().catch(function () {});
            } else {
              video.pause();
            }
          });
        },
        { threshold: 0.5 }
      );
      cards.forEach(function (card) { observer.observe(card); });
    }

    // ===== LIGHTBOX: ingrandisci video al click =====
    var lightbox = document.getElementById('tecnica-lightbox');
    var lightboxVideo = document.getElementById('tecnica-lightbox-video');
    var lightboxTitle = document.getElementById('tecnica-lightbox-title');
    var lightboxDesc = document.getElementById('tecnica-lightbox-desc');
    var lightboxClose = document.getElementById('tecnica-lightbox-close');
    var lastFocused = null;

    if (lightbox && lightboxVideo && lightboxClose) {
      function openLightbox(data) {
        lastFocused = document.activeElement;
        lightboxVideo.src = data.video;
        lightboxVideo.poster = data.poster;
        lightboxTitle.textContent = data.title;
        lightboxDesc.textContent = data.desc;
        lightbox.classList.remove('hidden');
        lightbox.classList.add('flex');
        lightboxVideo.currentTime = 0;
        lightboxVideo.play().catch(function () {});
        lightboxClose.focus();
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        lightbox.classList.add('hidden');
        lightbox.classList.remove('flex');
        lightboxVideo.pause();
        lightboxVideo.removeAttribute('src');
        lightboxVideo.load();
        document.body.style.overflow = '';
        if (lastFocused && lastFocused.focus) lastFocused.focus();
      }

      lightboxVideo.addEventListener('click', function () {
        if (lightboxVideo.paused) lightboxVideo.play();
        else lightboxVideo.pause();
      });

      document.querySelectorAll('.tecnica-expand').forEach(function (btn) {
        btn.addEventListener('click', function () {
          openLightbox({
            video: btn.dataset.video,
            poster: btn.dataset.poster,
            title: btn.dataset.title,
            desc: btn.dataset.desc,
          });
        });
      });

      lightboxClose.addEventListener('click', closeLightbox);
      lightbox.addEventListener('click', function (e) {
        if (e.target === lightbox) closeLightbox();
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
      });
    }
  });
</script>
