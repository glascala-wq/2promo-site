---
export interface FaqItem {
  q: string;
  a: string;
  open?: boolean;
}

interface Props {
  items: FaqItem[];
  eyebrow?: string;
  heading?: string;
}

const {
  items,
  eyebrow = 'domande frequenti',
  heading = 'Le solite domande,<br>risposte oneste.',
} = Astro.props;

// FAQPage JSON-LD (GEO/SEO) — auto-generato dagli stessi items, niente dati duplicati.
// Anti-breakout dello script tag: escape di </ in caso di HTML dentro le risposte.
const faqJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.q.replace(/<[^>]+>/g, ''),
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a.replace(/<[^>]+>/g, ''),
    },
  })),
}).replace(/</g, '\\u003c');
---

<section id="faq" class="bg-cream pb-24 md:pb-32">
  <div class="max-w-4xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="w-8 h-px bg-ink"></span>
      <span class="eyebrow text-ink/70">{eyebrow}</span>
    </div>
    <h2 class="font-display-tight text-5xl md:text-6xl leading-[0.95] mb-12" data-reveal set:html={heading} />
    <div class="space-y-3">
      {items.map((item, i) => (
        <details
          class="faq-item border-2 border-ink/10 rounded-2xl bg-cream hover:border-orange transition"
          open={item.open || i === 0}
        >
          <summary class="cursor-pointer p-6 flex items-center justify-between gap-6">
            <span class="font-display text-lg md:text-xl text-ink">{item.q}</span>
            <span class="faq-icon text-orange text-3xl font-light leading-none">+</span>
          </summary>
          <div class="px-6 pb-6 text-ink/70 leading-relaxed" set:html={item.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<script type="application/ld+json" set:html={faqJsonLd} />
