---
// ⚠️ NO "24h" per policy brand (memory.md 12 mag 2026) — usare "rapida"
interface Props {
  variant?: 'standard' | 'custom';
}
const { variant = 'standard' } = Astro.props;
---

<section class="bg-cream py-24 md:py-32">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="w-8 h-px bg-ink"></span>
      <span class="eyebrow text-ink/70">come funziona</span>
    </div>
    {variant === 'standard' ? (
      <>
        <h2 class="font-display-tight text-5xl md:text-7xl leading-[0.95] mb-16 max-w-4xl" data-reveal>
          Quattro passaggi,<br>zero <span class="underline-orange">sorprese</span>.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">01</div>
            <h3 class="font-display text-2xl text-ink mb-2">Brief</h3>
            <p class="text-ink/70">Dite cosa vi serve. Anche per messaggio vocale, basta non cantarlo.</p>
          </div>
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">02</div>
            <h3 class="font-display text-2xl text-ink mb-2">Preventivo + bozza rapida</h3>
            <p class="text-ink/70">Prezzi, tempi e bozza visiva. <strong class="text-ink">Gratis. Senza impegno.</strong></p>
          </div>
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">03</div>
            <h3 class="font-display text-2xl text-ink mb-2">Conferma</h3>
            <p class="text-ink/70">Approvate la bozza, partiamo con la produzione.</p>
          </div>
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">04</div>
            <h3 class="font-display text-2xl text-ink mb-2">Stampa & spedizione</h3>
            <p class="text-ink/70">In 2-3 giorni il vostro logo è ovunque. Su richiesta organizziamo consegne express.</p>
          </div>
        </div>
      </>
    ) : (
      <>
        <h2 class="font-display-tight text-5xl md:text-7xl leading-[0.95] mb-14 max-w-4xl" data-reveal>
          Stesso processo,<br>solo un po' <span class="underline-orange">più ragionato</span>.
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">01</div>
            <h3 class="font-display text-2xl text-ink mb-2">Brief</h3>
            <p class="text-ink/70">Forma, Pantone, quantità, deadline. Anche un disegno fatto a mano va bene.</p>
          </div>
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">02</div>
            <h3 class="font-display text-2xl text-ink mb-2">Bozza digitale rapida</h3>
            <p class="text-ink/70">Render fotorealistico. <strong class="text-ink">Gratuito.</strong></p>
          </div>
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">03</div>
            <h3 class="font-display text-2xl text-ink mb-2">Conferma</h3>
            <p class="text-ink/70">Approvate la bozza, partiamo con la produzione.</p>
          </div>
          <div data-reveal>
            <div class="font-display-tight text-orange text-7xl mb-4">04</div>
            <h3 class="font-display text-2xl text-ink mb-2">Produzione 12-15 gg</h3>
            <p class="text-ink/70">Pantone matching, edge-to-edge, controllo qualità.</p>
          </div>
        </div>
      </>
    )}
  </div>
</section>
