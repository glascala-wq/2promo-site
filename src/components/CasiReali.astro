---
// CasiReali — griglia foto lavori reali con cliente identificato (trust signal)
const photos = [
  { src: '/casestudy/polo-poyry.webp',            alt: 'Polo aziendale per Pöyry / AFRY',   prod: 'Polo',        cli: 'Pöyry / AFRY',       eager: true },
  { src: '/casestudy/felpa-beebad.webp',          alt: 'Felpa con cappuccio per beebad',    prod: 'Felpa',       cli: 'beebad',             eager: true },
  { src: '/casestudy/cappellino-beebad.webp',     alt: 'Cappellino ricamato per beebad',    prod: 'Cappellino',  cli: 'beebad',             eager: true },
  { src: '/casestudy/portachiavi-aero.webp',      alt: 'Portachiavi in pelle per Aero Club Biella', prod: 'Portachiavi', cli: 'Aero Club Biella', eager: true },
  { src: '/casestudy/sacca-guru.webp',            alt: 'Sacche coulisse per Guru',          prod: 'Sacche',      cli: 'Guru',               eager: false },
  { src: '/casestudy/cappellino-guru.webp',       alt: 'Cappellino per Guru',               prod: 'Cappellino',  cli: 'Guru',               eager: false },
  { src: '/casestudy/borraccia-deanery.webp',     alt: 'Borracce per Deanery',              prod: 'Borracce',    cli: 'Deanery',            eager: false },
  { src: '/casestudy/tshirt-deanery.webp',        alt: 'T-shirt per Deanery',               prod: 'T-shirt',     cli: 'Deanery',            eager: false },
  { src: '/casestudy/vetrofania-mediaworld.webp', alt: 'Vetrofania per MediaWorld',         prod: 'Vetrofania',  cli: 'MediaWorld',         eager: false },
  { src: '/casestudy/gadget-radioitalia.webp',    alt: 'Gadget evento per Radio Italia',    prod: 'Gadget evento', cli: 'Radio Italia',     eager: false },
  { src: '/casestudy/banner-monge.webp',          alt: 'Banner sponsorizzazione per Monge', prod: 'Banner',      cli: 'Monge',              eager: false },
];
---

<section id="casi-reali" class="bg-cream py-20 md:py-24 border-t border-ink/10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="w-8 h-px bg-ink"></span>
      <span class="eyebrow text-ink/70">— lavori veri</span>
    </div>
    <div class="flex items-end justify-between flex-wrap gap-6 mb-10" data-reveal>
      <h2 class="font-display-tight text-5xl md:text-7xl text-ink leading-[0.9]">
        Cosa abbiamo<br>stampato di recente.
      </h2>
      <p class="text-ink/70 text-lg max-w-md">
        Lavori finiti per i brand che ci scelgono. Prodotti veri, stampe vere, clienti veri.
      </p>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
      {photos.map((p) => (
        <figure class="m-0 group">
          <div class="overflow-hidden rounded-2xl bg-ink/5" style="aspect-ratio:3/4;">
            <img
              src={p.src}
              alt={p.alt}
              loading={p.eager ? 'eager' : 'lazy'}
              class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
              width="900"
              height="1200"
            />
          </div>
          <figcaption class="px-1 pt-2 text-xs text-ink/60 font-bold">{p.prod} · {p.cli}</figcaption>
        </figure>
      ))}
    </div>

    <p class="text-center mt-10 text-ink/60 text-sm">
      Tra i nostri clienti: Red Bull, MediaWorld, Monge, Radio Italia, Prato Nevoso e tanti altri.
      <a href="/preventivo" class="text-orange font-bold hover:underline ml-1">Chiedeteci una proposta →</a>
    </p>
  </div>
</section>
