---
// Showcase — bestseller magazine, 10 prodotti, marquee bidirezionale
// Immagini catalogo (build-time fetch dal gateway prodotti)

const products = [
  { img: '/products/product-2279.jpg',  name: 'Power bank 5000 mAh',      cat: 'tech',      bg: 'bg-navy text-cream',                     pill: 'bg-orange text-cream' },
  { img: '/products/borraccia-rpet.jpg', name: 'Borraccia sportiva 1L',    cat: 'drinkware', bg: 'bg-cream text-ink border border-ink/10',  pill: 'bg-ink text-cream' },
  { img: '/products/shopper-cotone.jpg', name: 'Shopper cotone bio',       cat: 'eco',       bg: 'bg-orange-pale text-ink',                pill: 'bg-orange text-cream' },
  { img: '/products/penna-sfera.jpg',    name: 'Penna a sfera premium',    cat: 'office',    bg: 'bg-ink text-cream',                      pill: 'bg-orange text-cream' },
  { img: '/products/zaino-rpet.jpg',     name: 'Zaino laptop RPET',        cat: 'lifestyle', bg: 'bg-cream text-ink border border-ink/10',  pill: 'bg-ink text-cream' },
  { img: '/products/product-9963.jpg',   name: 'Porta tè in vetro 850ml',  cat: 'drinkware', bg: 'bg-navy text-cream',                     pill: 'bg-orange text-cream' },
  { img: '/products/product-6451.jpg',   name: 'Porta telefono in bambù',  cat: 'office',    bg: 'bg-orange-pale text-ink',                pill: 'bg-orange text-cream' },
  { img: '/products/ombrello.jpg',       name: 'Ombrello automatico',      cat: 'lifestyle', bg: 'bg-ink text-cream',                      pill: 'bg-orange text-cream' },
  { img: '/products/taccuino-a5.jpg',    name: 'Taccuino A5',              cat: 'office',    bg: 'bg-cream text-ink border border-ink/10',  pill: 'bg-ink text-cream' },
  { img: '/products/product-2156.jpg',   name: 'Set connettori 9 in 1',    cat: 'tech',      bg: 'bg-navy text-cream',                     pill: 'bg-orange text-cream' },
];

const row1 = products.slice(0, 5);
const row2 = products.slice(5, 10);

const pills = ['tech', 'drinkware', 'eco', 'textile', 'office', 'lifestyle'];
---

<section class="bg-cream py-20 md:py-24 overflow-hidden border-y border-ink/10">
  <div class="max-w-7xl mx-auto px-6 mb-8">
    <div class="flex items-center gap-3 mb-5" data-reveal>
      <span class="w-8 h-px bg-ink"></span>
      <span class="eyebrow text-ink/70">— i più richiesti</span>
    </div>
    <h2 class="font-display-tight text-5xl md:text-7xl text-ink leading-[0.9] mb-6" data-reveal>
      Bestseller del momento.
    </h2>
    <div class="flex flex-wrap gap-2" data-reveal>
      {pills.map((p, i) => (
        <span class={`px-3 py-1 rounded-full text-xs font-bold tracking-wide ${i === 2 ? 'bg-orange text-cream' : 'bg-ink/5 text-ink/70'}`}>{p}</span>
      ))}
    </div>
  </div>

  <!-- Row 1 — scroll left -->
  <div class="relative mb-4 overflow-hidden">
    <div class="flex gap-5 marquee-track-fast">
      {[0, 1].map(set => (
        <div class="flex gap-5 shrink-0 items-stretch" aria-hidden={set === 1 ? 'true' : 'false'}>
          {row1.map((p, i) => (
            <div class={`showcase-card relative rounded-3xl overflow-hidden w-[240px] md:w-[280px] flex-shrink-0 flex flex-col ${p.bg}`}>
              <div class={`absolute top-4 left-4 z-10 px-3 py-1 rounded-full text-xs font-bold tracking-wide ${p.pill}`}>{p.cat}</div>
              <div class="overflow-hidden bg-white aspect-[4/3]">
                <img src={p.img} alt={`${p.name} personalizzato con logo aziendale`} class="w-full h-full object-cover" loading="lazy" width="280" height="210" />
              </div>
              <div class="p-4 md:p-5">
                <div class="font-display text-base md:text-lg mb-0.5 truncate">{p.name}</div>
                <div class="text-xs md:text-sm opacity-60">Da 25 pezzi</div>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>

  <!-- Row 2 — scroll right (reverse) -->
  <div class="relative overflow-hidden">
    <div class="flex gap-5 marquee-track-rev">
      {[0, 1].map(set => (
        <div class="flex gap-5 shrink-0 items-stretch" aria-hidden={set === 1 ? 'true' : 'false'}>
          {row2.map((p) => (
            <div class={`showcase-card relative rounded-3xl overflow-hidden w-[240px] md:w-[280px] flex-shrink-0 flex flex-col ${p.bg}`}>
              <div class={`absolute top-4 left-4 z-10 px-3 py-1 rounded-full text-xs font-bold tracking-wide ${p.pill}`}>{p.cat}</div>
              <div class="overflow-hidden bg-white aspect-[4/3]">
                <img src={p.img} alt={`${p.name} personalizzato con logo aziendale`} class="w-full h-full object-cover" loading="lazy" width="280" height="210" />
              </div>
              <div class="p-4 md:p-5">
                <div class="font-display text-base md:text-lg mb-0.5 truncate">{p.name}</div>
                <div class="text-xs md:text-sm opacity-60">Da 25 pezzi</div>
              </div>
            </div>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>
