---
// Catalogo completo gara — fuori dai 3 kit, CTA a preventivo classico.
// Foto prodotto: solo dove disponibile una foto fornitore pulita (senza grafica demo/loghi) — vedi verticale-golf/mapping-prodotti.md.
// Gli altri item usano un placeholder visivo neutro, marcato [TBD-FOTO] nel TBD-REGISTRY.
const items = [
  { name: 'Fondali premiazione e media wall', image: null },
  { name: 'Gazebo hospitality', image: '/golf/products/gazebo-hospitality.webp' },
  { name: 'Banchetti segreteria', image: null },
  { name: 'Segnaletica percorso', image: null },
  { name: 'Gonfiabili', image: null },
  { name: 'Tovaglie e bandiere istituzionali', image: null },
];
---
<section id="catalogo" class="bg-cream py-24 md:py-28 border-t border-ink/10">
  <div class="max-w-6xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-6" data-reveal>
      <span class="eyebrow text-ink/70">catalogo completo gara</span>
    </div>
    <h2 class="font-display-tight text-4xl md:text-6xl leading-[1] mb-6 max-w-3xl" data-reveal>
      Tutto quello che serve per la gara, oltre ai kit.
    </h2>
    <p class="text-lg text-ink/70 max-w-2xl mb-14" data-reveal>
      Fondali per la premiazione, gazebo hospitality, banchetti segreteria, segnaletica percorso, gonfiabili, tovaglie e bandiere istituzionali. Un solo fornitore, un solo ordine, consegna confermata per la data gara.
    </p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-6 mb-14">
      {items.map((item) => (
        <div class="bg-white border-2 border-ink/10 rounded-2xl overflow-hidden" data-reveal>
          <div class="aspect-[4/3] bg-gray-light flex items-center justify-center">
            {item.image ? (
              <img src={item.image} alt={item.name} class="w-full h-full object-cover" width="600" height="450" loading="lazy" />
            ) : (
              <span class="text-ink/30 text-xs uppercase tracking-wide px-4 text-center">Foto in arrivo</span>
            )}
          </div>
          <div class="p-4">
            <p class="font-display text-sm text-ink leading-snug">{item.name}</p>
          </div>
        </div>
      ))}
    </div>
    <a
      href="/preventivo"
      class="btn-orange inline-block bg-orange text-cream px-8 py-4 text-sm font-bold tracking-wide rounded-full hover:bg-ink transition"
      style="text-decoration:none;"
    >
      Richiedi Preventivo Catalogo Completo →
    </a>
  </div>
</section>
