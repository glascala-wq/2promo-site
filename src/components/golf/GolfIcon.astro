---
// Set di icone originali (disegnate da zero, nessuna derivazione da asset fornitore) per gli item
// del catalogo golf che non hanno ancora una foto prodotto reale. Stile lineare coerente: navy/cream
// a tratto, accento arancio, viewBox 120x120.
interface Props {
  name: 'fondale' | 'gazebo' | 'banchetto' | 'segnaletica' | 'gonfiabile' | 'tovaglia' | 'rollup' | 'totem' | 'bandiera-buca';
  class?: string;
}
const { name, class: className = '' } = Astro.props;
---
{name === 'banchetto' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <rect x="22" y="52" width="76" height="10" rx="3" stroke="currentColor" stroke-width="4"/>
    <path d="M30 62 L30 96 Q30 100 34 100 L86 100 Q90 100 90 96 L90 62" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
    <rect x="40" y="72" width="40" height="10" rx="2" fill="#FE5000"/>
  </svg>
)}
{name === 'segnaletica' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <path d="M38 100 L48 30 Q49 24 55 24 L65 24 Q71 24 72 30 L82 100" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
    <line x1="42" y1="72" x2="78" y2="72" stroke="currentColor" stroke-width="4"/>
    <path d="M54 48 L68 55 L54 62" stroke="#FE5000" stroke-width="5" stroke-linejoin="round" stroke-linecap="round"/>
  </svg>
)}
{name === 'rollup' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <rect x="42" y="18" width="36" height="8" rx="3" stroke="currentColor" stroke-width="4"/>
    <rect x="45" y="26" width="30" height="58" stroke="currentColor" stroke-width="4"/>
    <rect x="45" y="60" width="30" height="10" fill="#FE5000"/>
    <line x1="60" y1="84" x2="60" y2="98" stroke="currentColor" stroke-width="4"/>
    <ellipse cx="60" cy="100" rx="20" ry="6" stroke="currentColor" stroke-width="4"/>
  </svg>
)}
{name === 'totem' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <rect x="48" y="16" width="24" height="76" rx="4" stroke="currentColor" stroke-width="4"/>
    <rect x="48" y="40" width="24" height="14" fill="#FE5000"/>
    <rect x="34" y="92" width="52" height="10" rx="2" stroke="currentColor" stroke-width="4"/>
  </svg>
)}
{name === 'bandiera-buca' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <ellipse cx="60" cy="100" rx="34" ry="8" stroke="currentColor" stroke-width="4"/>
    <line x1="60" y1="100" x2="60" y2="22" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
    <path d="M60 24 L92 34 L60 44 Z" fill="#FE5000"/>
  </svg>
)}
{name === 'tovaglia' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <path d="M8 58 H62 V80 Q62 84 58 84 H12 Q8 84 8 80 Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
    <path d="M8 58 Q13 66 18 58 Q23 66 28 58 Q33 66 38 58 Q43 66 48 58 Q53 66 62 58" stroke="currentColor" stroke-width="3.5"/>
    <line x1="92" y1="92" x2="92" y2="24" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
    <path d="M92 26 L114 35 L92 44 Z" fill="#FE5000"/>
  </svg>
)}
{name === 'fondale' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <rect x="24" y="20" width="72" height="60" rx="4" stroke="currentColor" stroke-width="4"/>
    <line x1="24" y1="40" x2="96" y2="40" stroke="#FE5000" stroke-width="4"/>
    <line x1="44" y1="80" x2="44" y2="96" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
    <line x1="76" y1="80" x2="76" y2="96" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
  </svg>
)}
{name === 'gazebo' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <path d="M60 20 L96 46 H24 Z" stroke="currentColor" stroke-width="4" stroke-linejoin="round"/>
    <path d="M30 46 L26 98 M90 46 L94 98 M42 46 L40 98 M78 46 L80 98" stroke="currentColor" stroke-width="4" stroke-linecap="round"/>
    <line x1="24" y1="46" x2="96" y2="46" stroke="#FE5000" stroke-width="4"/>
  </svg>
)}
{name === 'gonfiabile' && (
  <svg viewBox="0 0 120 120" fill="none" xmlns="http://www.w3.org/2000/svg" class={className} aria-hidden="true">
    <path d="M26 98 V64 Q26 26 60 26 Q94 26 94 64 V98" stroke="currentColor" stroke-width="10" stroke-linecap="round"/>
    <path d="M40 60 Q60 50 80 60" stroke="#FE5000" stroke-width="4" stroke-linecap="round"/>
  </svg>
)}
