---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = '2promo.it — Stampiamo su tutto, per davvero',
  description = 'Gadget aziendali personalizzati B2B. 30.000+ articoli a catalogo, linea custom su misura da 10 pezzi. Dal 2014.',
  ogImage = '/og-image.png',
  noindex = false,
} = Astro.props;

const GA4_ID = import.meta.env.PUBLIC_GA4_ID ?? 'G-96YJ53PK26';
const GADS_ID = import.meta.env.PUBLIC_GOOGLE_ADS_ID ?? 'AW-16941964190';
const META_PIXEL_ID = import.meta.env.PUBLIC_META_PIXEL_ID ?? '1547004352951203';

// URL assolute basate su `site` (astro.config.mjs) — evita canonical/og localhost
const SITE = Astro.site ?? new URL('https://www.2promo.it');
const canonicalURL = new URL(Astro.url.pathname, SITE);
const ogImageURL = new URL(ogImage, SITE);
---

<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="2promo.it" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImageURL.href} />
  <meta property="og:url" content={canonicalURL.href} />
  <meta property="og:locale" content="it_IT" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageURL.href} />

  <!-- Canonical -->
  <link rel="canonical" href={canonicalURL.href} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Structured data (Organization + WebSite) -->
  <SchemaOrg />

  <!-- ========================================
       CONSENT MODE v2 — DEVE ESSERE PRIMA di gtag.js
       ======================================== -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
      ad_storage: 'denied',
      analytics_storage: 'denied',
      ad_user_data: 'denied',
      ad_personalization: 'denied',
      wait_for_update: 500
    });
  </script>

  <!-- ========================================
       GOOGLE TAG — Google Ads come ID PRIMARIO
       (gotcha: AW come primary, GA4 come secondary)
       ======================================== -->
  <script is:inline define:vars={{ GADS_ID, GA4_ID }}>
    // Coda gtag disponibile subito (Consent Mode già impostato sopra)
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', GADS_ID);
    gtag('config', GA4_ID);
    // Carica lo script gtag (~350KB) al primo segnale di interazione utente,
    // o come fallback dopo 4s di idle. Evita di competere con il main thread
    // nella finestra LCP (grande guadagno performance mobile).
    function loadGtag(){
      if (window.__gtagLoaded) return;
      window.__gtagLoaded = true;
      var s = document.createElement('script');
      s.async = true;
      s.src = 'https://www.googletagmanager.com/gtag/js?id=AW-16941964190';
      document.head.appendChild(s);
    }
    ['scroll','pointerdown','keydown','touchstart','mousemove'].forEach(function(ev){
      window.addEventListener(ev, loadGtag, { once: true, passive: true });
    });
    // Fallback idle: se l'utente non interagisce, carica comunque dopo 4s
    (window.requestIdleCallback || window.setTimeout)(function(){ setTimeout(loadGtag, 4000); }, { timeout: 5000 });
  </script>

  <!-- GSAP + ScrollTrigger (from CDN) — defer per non bloccare il render -->
  <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer is:inline></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js" defer is:inline></script>
</head>
<body class="font-body antialiased">

  <main>
    <slot />
  </main>

  <CookieBanner metaPixelId={META_PIXEL_ID} />

  <!-- Sticky CTA Mobile — dual button -->
  <div id="sticky-cta" class="md:hidden fixed bottom-4 left-4 right-4 flex gap-3 z-30 transition-all duration-300">
    <a
      href="https://wa.me/393451448645?text=Ciao%202promo%2C%20vorrei%20un%20preventivo"
      target="_blank"
      rel="noopener"
      class="flex-1 bg-cream border-2 border-ink text-ink text-center py-4 px-3 rounded-full font-bold text-sm shadow-xl flex items-center justify-center gap-2"
      style="text-decoration:none;"
      aria-label="Scrivici su WhatsApp"
    >
      <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current shrink-0" aria-hidden="true"><path d="M17.6 6.32A7.85 7.85 0 0 0 12.05 4 7.94 7.94 0 0 0 5.1 16.16L4 20.66l4.66-1.22a7.94 7.94 0 0 0 3.79.97h.01a7.94 7.94 0 0 0 7.94-7.93 7.88 7.88 0 0 0-2.8-6.16zM12.05 18.95h-.01a6.58 6.58 0 0 1-3.36-.92l-.24-.14-2.77.72.74-2.7-.16-.25a6.6 6.6 0 1 1 12.21-3.5 6.61 6.61 0 0 1-6.41 6.79zm3.62-4.94c-.2-.1-1.18-.58-1.36-.65-.18-.07-.31-.1-.45.1-.13.2-.51.65-.62.78-.11.13-.23.15-.43.05a5.43 5.43 0 0 1-2.71-2.37c-.2-.35.2-.32.59-1.08.07-.13.03-.25-.02-.35-.05-.1-.45-1.08-.62-1.48-.16-.39-.33-.34-.45-.34h-.39c-.13 0-.35.05-.53.25-.18.2-.7.68-.7 1.66 0 .98.71 1.92.81 2.05.1.13 1.4 2.13 3.39 2.99 1.99.86 1.99.57 2.35.53.36-.04 1.18-.48 1.34-.95.17-.46.17-.86.12-.95-.05-.08-.18-.13-.38-.23z"/></svg>
      WhatsApp
    </a>
    <a
      href="/preventivo"
      class="flex-1 bg-orange text-cream text-center py-4 px-3 rounded-full font-bold text-sm shadow-xl shadow-orange/30"
      style="text-decoration:none;"
    >
      Preventivo →
    </a>
  </div>

  <!-- GSAP Reveal + Kinetic + Nav shrink + Counters + Sticky CTA observer -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {

      // ===== NAV SHRINK =====
      const nav = document.getElementById('nav');
      if (nav) {
        const observer = new IntersectionObserver(
          ([e]) => nav.classList.toggle('nav-shrunk', !e.isIntersecting),
          { threshold: 0 }
        );
        const firstSection = document.querySelector('header, section');
        if (firstSection) observer.observe(firstSection);
      }

      // ===== GSAP REVEAL =====
      if (typeof gsap !== 'undefined' && typeof ScrollTrigger !== 'undefined') {
        gsap.registerPlugin(ScrollTrigger);
        gsap.utils.toArray('[data-reveal]').forEach(function(el) {
          gsap.fromTo(el,
            { opacity: 0, y: 24 },
            {
              opacity: 1, y: 0,
              duration: 0.7,
              ease: 'cubic-bezier(0.2, 0.8, 0.2, 1)',
              scrollTrigger: {
                trigger: el,
                start: 'top 88%',
                once: true
              }
            }
          );
        });
      }

      // ===== KINETIC TEXT =====
      // kinetic text rimosso — parola fissa "tutto"

      // ===== COUNTERS =====
      function animateCounter(el, target, duration) {
        var start = 0;
        var step = target / (duration / 16);
        var timer = setInterval(function() {
          start += step;
          if (start >= target) { start = target; clearInterval(timer); }
          el.textContent = Math.floor(start).toLocaleString('it-IT');
        }, 16);
      }
      document.querySelectorAll('.counter').forEach(function(el) {
        var target = parseInt(el.dataset.target || '0', 10);
        if (typeof IntersectionObserver !== 'undefined') {
          var obs = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                animateCounter(el, target, 1200);
                obs.disconnect();
              }
            });
          }, { threshold: 0.5 });
          obs.observe(el);
        } else {
          el.textContent = target.toLocaleString('it-IT');
        }
      });

      // ===== STICKY CTA — nasconde quando form è visibile =====
      var stickyCta = document.getElementById('sticky-cta');
      var formSection = document.getElementById('preventivo');
      if (stickyCta && formSection) {
        var formObs = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              stickyCta.style.transform = 'translateY(120px)';
              stickyCta.style.opacity = '0';
              stickyCta.style.pointerEvents = 'none';
            } else {
              stickyCta.style.transform = '';
              stickyCta.style.opacity = '';
              stickyCta.style.pointerEvents = '';
            }
          });
        }, { threshold: 0.1 });
        formObs.observe(formSection);
      }

    });
  </script>

  <!-- Pointer glow — alone arancione che segue il mouse (solo desktop, rispetta reduced-motion) -->
  <script is:inline>
    (function () {
      if (window.matchMedia('(hover: none), (pointer: coarse)').matches) return;
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      var glow = document.createElement('div');
      glow.className = 'pointer-glow';
      document.body.appendChild(glow);

      var targetX = window.innerWidth / 2;
      var targetY = window.innerHeight / 2;
      var currentX = targetX;
      var currentY = targetY;
      var active = false;

      window.addEventListener('mousemove', function (e) {
        targetX = e.clientX;
        targetY = e.clientY;
        if (!active) {
          active = true;
          glow.classList.add('is-active');
        }
      }, { passive: true });

      document.addEventListener('mouseleave', function () {
        active = false;
        glow.classList.remove('is-active');
      });

      function tick() {
        currentX += (targetX - currentX) * 0.12;
        currentY += (targetY - currentY) * 0.12;
        glow.style.transform = 'translate3d(' + (currentX - 300) + 'px, ' + (currentY - 300) + 'px, 0)';
        requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    })();
  </script>

</body>
</html>
