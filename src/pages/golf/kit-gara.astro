---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import Navbar from '../../components/Navbar.astro';
import Faq from '../../components/Faq.astro';
import Footer from '../../components/Footer.astro';
import GolfContactForm from '../../components/golf/GolfContactForm.astro';
import GolfProductSchema from '../../components/golf/GolfProductSchema.astro';
import { getGolfKit } from '../../data/golf-kits';

const kit = getGolfKit('kit-gara')!;

const faqItems = [
  {
    q: 'Chi paga di solito il Kit Gara Sponsor?',
    a: "Nella maggior parte dei casi lo sponsor della gara, non il circolo: è l'allestimento con cui lo sponsor porta il proprio brand sul percorso e alla premiazione. Ditecelo nel form se la fattura va intestata allo sponsor.",
    open: true,
  },
  {
    q: 'Possiamo personalizzare il numero di bandiere o tee marker?',
    a: 'Il kit è pensato come composizione a prezzo fisso. Per quantità diverse da quelle indicate, scrivetecelo nel messaggio del form: valutiamo insieme una composizione su misura a preventivo.',
  },
];
---

<BaseLayout
  title={kit.metaTitle}
  description={kit.metaDescription}
  noindex={true}
>
  <Breadcrumbs items={[{ name: 'Golf', url: '/golf' }, { name: kit.name, url: `/golf/${kit.slug}` }]} />
  <Navbar activeRoute="other" />
  <GolfProductSchema kit={kit} />

  <header class="relative overflow-hidden isolate bg-navy text-cream">
    <div class="absolute inset-0 glow-orange pointer-events-none opacity-40"></div>
    <div class="relative max-w-4xl mx-auto px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <a href="/golf#kit" class="text-sm text-cream/60 hover:text-orange transition inline-block mb-6">← Torna ai kit</a>
      <div class="flex items-center gap-3 mb-6" data-reveal>
        <span class="eyebrow text-orange">{kit.eyebrow}</span>
      </div>
      <h1 class="font-display-tight text-[9vw] md:text-[4vw] leading-[1.02] mb-6 max-w-3xl" data-reveal>
        {kit.name}: {kit.tagline}
      </h1>
      <p class="text-xl text-cream/80 max-w-2xl leading-relaxed" data-reveal>
        {kit.description}
      </p>
    </div>
  </header>

  <section class="bg-cream py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-6 grid grid-cols-1 md:grid-cols-[1.4fr_1fr] gap-10">
      <div data-reveal>
        <h2 class="font-display-tight text-2xl md:text-3xl text-ink mb-6">Cosa include</h2>
        <ul class="space-y-3">
          {kit.includes.map((item) => (
            <li class="flex items-start gap-3 text-ink/80">
              <span class="text-orange font-bold mt-0.5">✓</span>
              <span set:html={item} />
            </li>
          ))}
        </ul>
        <p class="text-ink/60 text-sm mt-8">
          Struttura acquistata una volta, grafica riordinabile a ogni gara — vedi <a href="/golf#struttura-grafica" class="text-orange underline">come funziona il modello struttura + grafica</a>.
        </p>
      </div>
      <div class="bg-white border-2 border-ink/10 rounded-2xl p-8 h-fit" data-reveal>
        <div class="eyebrow text-ink/50 mb-2">prezzo</div>
        <div class="font-display-tight text-3xl text-ink mb-2">{kit.priceLabel}</div>
        <p class="text-xs text-ink/50 mb-6">Grafica inclusa · consegna confermata per la data gara</p>
        <a
          href="#richiesta"
          class="btn-orange block text-center bg-orange text-cream py-4 px-6 text-sm font-bold tracking-wide rounded-full hover:bg-ink transition"
          style="text-decoration:none;"
        >
          Richiedi {kit.name} →
        </a>
      </div>
    </div>
  </section>

  <Faq items={faqItems} eyebrow={`domande su ${kit.name.toLowerCase()}`} heading="Le domande più frequenti<br>su questo kit." />
  <GolfContactForm preselectKit="kit-gara" />
  <Footer />
</BaseLayout>
