---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import UrgencyBar from '../components/UrgencyBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import TrustBar from '../components/TrustBar.astro';
import WhyCustom from '../components/WhyCustom.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Faq from '../components/Faq.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const faqCustom = [
  {
    q: 'Davvero ordine minimo da 10 pezzi?',
    a: 'Davvero. Su abbigliamento custom (t-shirt, polo, felpe) partiamo da 10 pezzi. Su altre famiglie gli ordini minimi variano: borse 100, cordini eventi 100, calzini 50. Sotto i 10 pezzi non riusciamo, ma una pre-serie da 10 sì.',
    open: true,
  },
  {
    q: 'Cosa intendete con Pantone esatto?',
    a: 'Riproduciamo il vostro colore <strong class="text-ink">esattamente</strong> come da codice Pantone, su tessuto o materiale personalizzato. Senza "rosa che diventa salmone in stampa" o "blu che vira sul viola".',
  },
  {
    q: 'La stampa su tutta la superficie si applica a tutto?',
    a: 'Dipende dal materiale e dalla tecnica. Su tessuti sintetici (RPET, poliestere) sì, stampa su tutta la superficie. Su cotone naturale e altri materiali ci sono limiti tecnici fisici. Nella bozza vi diciamo cosa è fattibile.',
  },
  {
    q: 'Posso vedere prototipi fisici prima di tutta la produzione?',
    a: 'Su ordini sopra i 500 pezzi possiamo fare un prototipo fisico prima della serie. Su ordini sotto i 500, ci affidiamo alla bozza digitale + un campione del materiale che vi spediamo.',
  },
];
---

<BaseLayout
  title="Gadget Personalizzati su Misura da 10 Pezzi | 2promo.it"
  description="Gadget personalizzati su misura per aziende: stampa su tutta la superficie, Pantone esatti, da 10 pezzi. T-shirt, shopper, lanyard, calzini. Bozza gratuita."
>
  <Breadcrumbs items={[{ name: 'Linea Custom', url: '/custom' }]} />
  <UrgencyBar />
  <Navbar activeRoute="custom" />
  <Hero variant="custom" />
  <SocialProof />
  <TrustBar />

  <!-- 3 USP cards -->
  <section class="bg-cream py-20 md:py-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-navy text-cream rounded-3xl p-8" data-reveal>
          <div class="font-display-tight text-orange text-5xl mb-4">01</div>
          <h3 class="font-display-tight text-3xl mb-3">Pantone esatto</h3>
          <p class="text-cream/70 leading-relaxed">Il vostro brand riprodotto come da pantoniera <strong class="text-cream">in tutto il prodotto, non solo in stampa</strong>. Tessitura, base, materiale: tutto generato col Pantone scelto. Senza approssimazioni.</p>
        </div>
        <div class="bg-orange text-cream rounded-3xl p-8" data-reveal>
          <div class="font-display-tight text-ink text-5xl mb-4">02</div>
          <h3 class="font-display-tight text-3xl mb-3">Edge-to-edge</h3>
          <p class="text-cream/90 leading-relaxed">Stampa su tutta la superficie, fino al bordo. Niente cornici bianche, niente "questa parte non si può stampare". Tutto è canvas.</p>
        </div>
        <div class="bg-ink text-cream rounded-3xl p-8" data-reveal>
          <div class="font-display-tight text-orange text-5xl mb-4">03</div>
          <h3 class="font-display-tight text-3xl mb-3">Da 10 pezzi in su</h3>
          <p class="text-cream/70 leading-relaxed">L'ordine minimo parte da 10 pezzi su misura. Anche per piccoli eventi, regali corporate, pre-serie e test pilota. Senza che vi dicano "eh ma sotto i 100 non si fa".</p>
        </div>
      </div>
      <p class="text-center text-ink/70 mt-10 max-w-3xl mx-auto">
        Una combinazione difficile da trovare insieme.
      </p>
    </div>
  </section>

  <!-- Categorie Custom -->
  <section class="bg-cream pb-20 md:pb-28">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6" data-reveal>
        <span class="w-8 h-px bg-ink"></span>
        <span class="eyebrow text-ink/70">cosa rendiamo custom</span>
      </div>
      <h2 class="font-display-tight text-5xl md:text-7xl text-ink leading-[0.95] mb-14 max-w-3xl" data-reveal>
        Quattro famiglie,<br>una libertà <span class="text-orange">totale</span>.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <a
          href="#preventivo"
          class="cat-card relative rounded-3xl overflow-hidden p-8 flex flex-col justify-between text-cream"
          style="background: linear-gradient(135deg, #FE5000 0%, #c63f00 100%); min-height: 260px; text-decoration:none;"
          data-reveal
        >
          <span class="eyebrow text-cream/80">abbigliamento</span>
          <div>
            <h3 class="font-display-tight text-4xl md:text-5xl leading-tight">T-shirt, polo, felpe.<br>Da <span class="underline-orange">10 pezzi</span>.</h3>
            <p class="cat-tag mt-3 text-sm font-bold">Stampa su tutta la superficie · Colore esatto come da pantoniera</p>
          </div>
        </a>
        <a
          href="#preventivo"
          class="cat-card relative rounded-3xl overflow-hidden p-8 flex flex-col justify-between bg-navy text-cream"
          style="min-height: 260px; text-decoration:none;"
          data-reveal
        >
          <span class="eyebrow text-orange">borse cotone</span>
          <div>
            <h3 class="font-display-tight text-4xl md:text-5xl leading-tight">Shopper integrali.<br>Da <span class="text-orange">100 pezzi</span>.</h3>
            <p class="cat-tag mt-3 text-sm font-bold">Stampa su tutta la superficie · forme personalizzate</p>
          </div>
        </a>
        <a
          href="#preventivo"
          class="cat-card relative rounded-3xl overflow-hidden p-8 flex flex-col justify-between bg-ink text-cream"
          style="min-height: 260px; text-decoration:none;"
          data-reveal
        >
          <span class="eyebrow text-orange">lanyards</span>
          <div>
            <h3 class="font-display-tight text-4xl md:text-5xl leading-tight">Cordini eventi.<br>Da <span class="text-orange">100 pezzi</span>.</h3>
            <p class="cat-tag mt-3 text-sm font-bold">Pantone esatti · stampa fronte/retro</p>
          </div>
        </a>
        <a
          href="#preventivo"
          class="cat-card relative rounded-3xl overflow-hidden p-8 flex flex-col justify-between bg-orange-pale text-ink"
          style="min-height: 260px; text-decoration:none;"
          data-reveal
        >
          <span class="eyebrow text-ink/70">calzini</span>
          <div>
            <h3 class="font-display-tight text-4xl md:text-5xl leading-tight">Calzini custom.<br>Da <span class="underline-orange">50 pezzi</span>.</h3>
            <p class="cat-tag mt-3 text-sm font-bold">Tessitura full-jacquard · 100% personalizzati</p>
          </div>
        </a>
      </div>
      <p class="text-ink/70 mt-8">+ 20 altre categorie custom (cappellini, sacche, ombrelli, drinkware, accessori, ecc.). Chiedete e vediamo.</p>
    </div>
  </section>

  <!-- Standard vs Custom comparison -->
  <section class="bg-ink text-cream py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <span class="w-8 h-px bg-orange"></span>
        <span class="eyebrow text-orange">perché la linea custom</span>
      </div>
      <h2 class="font-display-tight text-4xl md:text-6xl leading-[0.95] mb-12 max-w-4xl">
        Standard vs Custom,<br>in due parole.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border border-cream/20 rounded-2xl p-8">
          <div class="eyebrow text-cream/60 mb-3">il nostro catalogo</div>
          <h3 class="font-display-tight text-3xl mb-4">Catalogo 30.000+</h3>
          <ul class="space-y-2 text-cream/80">
            <li>· Da 1 pezzo campione (extra)</li>
            <li>· Stampa sulla zona prevista</li>
            <li>· Stampa colori Pantone</li>
            <li>· Consegna 3 giorni</li>
            <li>· Bozza visiva inclusa</li>
          </ul>
        </div>
        <div class="border-2 border-orange rounded-2xl p-8 bg-orange/5">
          <div class="eyebrow text-orange mb-3">su misura, dal nostro studio</div>
          <h3 class="font-display-tight text-3xl mb-4">Su misura, da 10 pezzi</h3>
          <ul class="space-y-2 text-cream/90">
            <li>· <strong>Ordine minimo da 10 pezzi</strong> su abbigliamento</li>
            <li>· <strong>Stampa su tutta la superficie</strong></li>
            <li>· <strong>Pantone esatto in produzione e stampa</strong></li>
            <li>· Consegna 12-15 giorni</li>
            <li>· Bozza visiva inclusa</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <WhyCustom />
  <HowItWorks variant="custom" />
  <Faq
    items={faqCustom}
    eyebrow="domande custom-specifiche"
    heading="Quello che chiedete di più."
  />
  <ContactForm id="preventivo" preselectLinea="custom" variant="navy" />
  <Footer />
</BaseLayout>
