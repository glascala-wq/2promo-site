---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import UrgencyBar from '../components/UrgencyBar.astro';
import Navbar from '../components/Navbar.astro';
import CatalogForm from '../components/CatalogForm.astro';
import Footer from '../components/Footer.astro';

const IFRAME_STANDARD = 'https://view.publitas.com/md-it/gifts_ita_without-prices_1/page/1';
const IFRAME_CUSTOM = 'https://view.publitas.com/md-it/25-1-yourchoice_ita_vr-dakgombypdjg/page/1';
const IFRAME_ABBIGLIAMENTO = 'https://catalogue.sologroup-paris.com/solo-group/e-catalogue-it-2026/?page=1';
const IFRAME_ALLESTIMENTI = '/cataloghi/display-allestimenti-2026.pdf';
---

<BaseLayout
  title="Catalogo Gadget Aziendali e Articoli Promozionali | 2promo.it"
  description="Sfoglia il catalogo: gadget aziendali personalizzati, abbigliamento, articoli eco e allestimenti fiera. 30.000+ articoli. Preventivo gratuito."
>
  <Breadcrumbs items={[{ name: 'Catalogo', url: '/catalogo' }]} />
  <UrgencyBar />
  <Navbar activeRoute="catalogo" />

  <!-- Hero compatto -->
  <header class="relative overflow-hidden isolate bg-cream">
    <div class="absolute inset-0 glow-orange pointer-events-none opacity-40"></div>
    <div class="relative max-w-7xl mx-auto px-6 pt-16 pb-12 md:pt-20 md:pb-16">
      <div class="flex items-center gap-3 mb-6" data-reveal>
        <span class="eyebrow text-ink/70">sfogliate, ispiratevi</span>
      </div>
      <h1 class="font-display-tight text-[10vw] md:text-[6vw] leading-[0.9] text-ink mb-6 max-w-4xl" data-reveal>
        Il catalogo gadget aziendali: quello che facciamo,<br>ogni <span class="underline-orange">giorno</span>.
      </h1>
      <p class="text-xl text-ink/75 max-w-2xl" data-reveal>
        Una selezione dei nostri cataloghi 2026. Il catalogo completo supera i <strong class="text-ink">30.000 articoli</strong>: qui trovate una scelta ragionata di quello che producono i nostri clienti più spesso.
      </p>
    </div>
  </header>

  <!-- Tab switcher + iframe -->
  <section class="bg-cream pb-20 md:pb-28">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Tab buttons -->
      <div class="flex gap-1 sm:gap-2 mb-8 border-b border-ink/10 overflow-x-auto">
        <button
          id="tab-standard"
          data-tab="standard"
          class="tab-btn whitespace-nowrap px-5 sm:px-7 py-4 text-lg md:text-xl font-display-tight border-b-4 border-orange text-ink transition"
        >
          Catalogo Standard
        </button>
        <button
          id="tab-custom"
          data-tab="custom"
          class="tab-btn whitespace-nowrap px-5 sm:px-7 py-4 text-lg md:text-xl font-display-tight border-b-4 border-transparent text-ink/70 hover:text-ink transition"
        >
          Linea Custom
        </button>
        <button
          id="tab-abbigliamento"
          data-tab="abbigliamento"
          class="tab-btn whitespace-nowrap px-5 sm:px-7 py-4 text-lg md:text-xl font-display-tight border-b-4 border-transparent text-ink/70 hover:text-ink transition"
        >
          Abbigliamento
        </button>
        <button
          id="tab-allestimenti"
          data-tab="allestimenti"
          class="tab-btn whitespace-nowrap px-5 sm:px-7 py-4 text-lg md:text-xl font-display-tight border-b-4 border-transparent text-ink/70 hover:text-ink transition"
        >
          Allestimenti
        </button>
      </div>

      <!-- Dynamic heading -->
      <div class="mb-8">
        <h2
          id="catalog-heading"
          class="font-display-tight text-lg md:text-xl text-ink/80 leading-tight mb-2"
        >
          Catalogo Standard · 484 pagine
        </h2>
        <p
          id="catalog-sub"
          class="text-ink/70 max-w-2xl"
        >
          Una selezione delle ultime stagioni. Senza prezzi pubblici: vi mandiamo un preventivo personalizzato dopo il vostro brief.
        </p>
      </div>

      <!-- Iframe Publitas 16:10 contained -->
      <div
        class="catalog-frame max-w-6xl mx-auto bg-cream rounded-2xl shadow-2xl overflow-hidden border border-ink/10"
        style="aspect-ratio: 16/10;"
      >
        <iframe
          id="catalog-iframe"
          src={IFRAME_STANDARD}
          title="Catalogo 2promo"
          class="w-full h-full"
          loading="lazy"
          allow="fullscreen"
          referrerpolicy="no-referrer"
        ></iframe>
      </div>

      <!-- Apri a tutto schermo (fallback utile, essenziale per il PDF su mobile) -->
      <div class="max-w-6xl mx-auto mt-4 text-right">
        <a
          id="catalog-open"
          href={IFRAME_STANDARD}
          target="_blank"
          rel="noopener"
          class="text-sm font-bold text-ink/60 hover:text-orange transition"
        >
          Apri a tutto schermo ↗
        </a>
      </div>

      <!-- Testo indicizzabile: il contenuto dei cataloghi vive negli iframe di terzi,
           qui riassumiamo cosa c'è dentro con le keyword che i clienti cercano davvero -->
      <div class="max-w-3xl mx-auto mt-16 text-ink/70 leading-relaxed space-y-4">
        <p>
          Nel <strong class="text-ink">catalogo standard</strong> trovate oltre 30.000 <strong class="text-ink">gadget aziendali personalizzati</strong>: borracce, power bank, shopper in cotone, penne, taccuini, ombrelli, <a href="/welcome-kit-aziendali" class="text-orange underline">welcome kit per dipendenti</a> e <a href="/regali-aziendali-natale" class="text-orange underline">regali aziendali per Natale</a>. Nella <strong class="text-ink">linea custom</strong> lavoriamo su misura da 10 pezzi: forme personalizzate, Pantone esatto, stampa su tutta la superficie. Il catalogo <strong class="text-ink">abbigliamento</strong> copre t-shirt, felpe, polo e workwear; gli <strong class="text-ink">allestimenti</strong> coprono stand fiera, banchetti, totem, gazebo, bandiere e roll-up per <a href="/gadget-fiere-eventi" class="text-orange underline">eventi e fiere</a>. Se vi interessano i <a href="/gadget-ecosostenibili" class="text-orange underline">materiali ecosostenibili</a>, abbiamo una guida dedicata alle certificazioni.
        </p>
        <div class="pt-4">
          <details class="faq-item border-2 border-ink/10 rounded-2xl bg-cream hover:border-orange transition">
            <summary class="cursor-pointer p-5 flex items-center justify-between gap-6">
              <span class="font-display text-base text-ink">Come ricevo i prezzi dei gadget personalizzati?</span>
              <span class="faq-icon text-orange text-2xl font-light leading-none">+</span>
            </summary>
            <div class="px-5 pb-5 text-ink/70 leading-relaxed">Il catalogo non ha prezzi pubblici: dopo il vostro brief (prodotto, quantità, logo) vi mandiamo un preventivo su misura, con bozza pre-stampa inclusa e gratuita.</div>
          </details>
          <details class="faq-item border-2 border-ink/10 rounded-2xl bg-cream hover:border-orange transition mt-3">
            <summary class="cursor-pointer p-5 flex items-center justify-between gap-6">
              <span class="font-display text-base text-ink">Posso avere il catalogo gadget aziendali in PDF?</span>
              <span class="faq-icon text-orange text-2xl font-light leading-none">+</span>
            </summary>
            <div class="px-5 pb-5 text-ink/70 leading-relaxed">Sì, lasciate l'email qui sotto e vi spediamo il PDF del catalogo standard, pronto da condividere col vostro team.</div>
          </details>
        </div>
      </div>

    </div>
  </section>

  <!-- Fuori catalogo — navy section -->
  <section class="bg-navy text-cream py-16 md:py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <div class="flex items-center justify-center gap-3 mb-6">
        <span class="eyebrow text-orange">e se non c'è quello che cercate?</span>
      </div>
      <h2 class="font-display-tight text-4xl md:text-5xl leading-tight mb-6">
        Non avete trovato<br>quello che cercate?
      </h2>
      <p class="text-lg text-cream/80 mb-8 leading-relaxed max-w-2xl mx-auto">
        Quelle che avete sfogliato sono una <strong class="text-cream">selezione</strong>:
        nel nostro catalogo completo ci sono oltre <strong class="text-cream">30.000 articoli</strong>,
        più tutta la Linea Custom su misura. Raccontateci cosa avete in mente:
        proponiamo noi le opzioni migliori o creiamo qualcosa di nuovo.
      </p>
      <a
        href="/preventivo"
        class="btn-orange bg-orange text-cream px-8 py-4 rounded-full font-bold tracking-wide hover:bg-cream hover:text-ink transition"
        style="text-decoration:none;"
      >
        Chiedeteci una proposta →
      </a>
    </div>
  </section>

  <CatalogForm />
  <Footer />
</BaseLayout>

<script is:inline define:vars={{ IFRAME_STANDARD, IFRAME_CUSTOM, IFRAME_ABBIGLIAMENTO, IFRAME_ALLESTIMENTI }}>
  (function() {
    var headings = {
      standard: {
        h2: 'Catalogo Standard · 484 pagine',
        sub: 'Una selezione delle ultime stagioni. Senza prezzi pubblici: vi mandiamo un preventivo personalizzato dopo il vostro brief.'
      },
      custom: {
        h2: 'Linea Custom · 268 pagine',
        sub: 'Esempi di lavori su misura: stampa su tutta la superficie, Pantone esatto, ordine minimo 10 pezzi. Quello che fate voi può essere completamente diverso. Raccontatecelo.'
      },
      abbigliamento: {
        h2: 'Abbigliamento · 308 pagine',
        sub: 'T-shirt, felpe, polo, workwear e accessori pronti da personalizzare col vostro logo. Ricamo o stampa, dai piccoli lotti alle grandi quantità.'
      },
      allestimenti: {
        h2: 'Allestimenti · 142 pagine',
        sub: 'Soluzioni per la comunicazione visiva: stand fiera, fondali, totem, banchetti, segnaletica, gazebo, bandiere, rollup e banner. Da personalizzare col vostro brand.'
      }
    };
    var iframeSrc = {
      standard: IFRAME_STANDARD,
      custom: IFRAME_CUSTOM,
      abbigliamento: IFRAME_ABBIGLIAMENTO,
      allestimenti: IFRAME_ALLESTIMENTI
    };
    var validTabs = ['standard', 'custom', 'abbigliamento', 'allestimenti'];

    var tabButtons = Array.prototype.slice.call(document.querySelectorAll('.tab-btn'));
    var iframe = document.getElementById('catalog-iframe');
    var heading = document.getElementById('catalog-heading');
    var sub = document.getElementById('catalog-sub');
    var openLink = document.getElementById('catalog-open');

    function setTab(tab) {
      // Update buttons (attivo = arancio, altri = grigi)
      tabButtons.forEach(function(btn) {
        var active = btn.getAttribute('data-tab') === tab;
        btn.classList.toggle('border-orange', active);
        btn.classList.toggle('text-ink', active);
        btn.classList.toggle('border-transparent', !active);
        btn.classList.toggle('text-ink/70', !active);
      });

      // Update heading + sub with fade
      heading.style.opacity = '0';
      sub.style.opacity = '0';
      setTimeout(function() {
        heading.textContent = headings[tab].h2;
        sub.textContent = headings[tab].sub;
        heading.style.transition = 'opacity 0.3s';
        sub.style.transition = 'opacity 0.3s';
        heading.style.opacity = '1';
        sub.style.opacity = '1';
      }, 150);

      // Update "apri a tutto schermo" link
      if (openLink) openLink.href = iframeSrc[tab];

      // Update iframe with fade
      iframe.style.opacity = '0';
      iframe.style.transition = 'opacity 0.3s';
      setTimeout(function() {
        iframe.src = iframeSrc[tab];
        iframe.style.opacity = '1';
      }, 300);

      // Update URL without reload
      var url = new URL(window.location.href);
      if (tab === 'standard') {
        url.searchParams.delete('linea');
      } else {
        url.searchParams.set('linea', tab);
      }
      history.replaceState(null, '', url.toString());
    }

    // Read initial state from URL
    var params = new URLSearchParams(window.location.search);
    var initialTab = params.get('linea');
    if (validTabs.indexOf(initialTab) !== -1 && initialTab !== 'standard') {
      setTab(initialTab);
    }

    tabButtons.forEach(function(btn) {
      btn.addEventListener('click', function() { setTab(btn.getAttribute('data-tab')); });
    });
  })();
</script>
