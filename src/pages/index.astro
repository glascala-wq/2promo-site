---
import BaseLayout from '../layouts/BaseLayout.astro';
import UrgencyBar from '../components/UrgencyBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Trust from '../components/Trust.astro';
import Counters from '../components/Counters.astro';
import Categories from '../components/Categories.astro';
import Showcase from '../components/Showcase.astro';
import CasiReali from '../components/CasiReali.astro';
import EscapeHatchCustom from '../components/EscapeHatchCustom.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Faq from '../components/Faq.astro';
import Certifications from '../components/Certifications.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

const faqItems = [
  {
    q: 'Tempi di consegna?',
    a: 'A partire da 2-3 giorni dalla conferma per gli ordini standard (il tempo esatto dipende da prodotto e quantità). 12-15 giorni per la linea custom. Su richiesta organizziamo consegne express per scadenze urgenti.',
    open: true,
  },
  {
    q: 'Posso vedere una bozza prima di pagare?',
    a: 'Sì, sempre. Bozza visiva inclusa nel preventivo, gratuita, in 24h. Approvate prima, pagate dopo. Mai mockup dopo pagamento.',
  },
  {
    q: 'Posso ordinare piccoli quantitativi per testare?',
    a: 'Sì, anche un singolo pezzo come campione su molti articoli del catalogo standard. Sulla Linea Custom partiamo da 10 pezzi su misura. Per collezioni particolari definiamo insieme un lotto pilota personalizzato.',
  },
  {
    q: 'Che tipi di stampa offrite?',
    a: 'Serigrafia, tampografia, transfer digitale, incisione laser, ricamo. Il nostro reparto tecnico vi consiglia la tecnica migliore in base al materiale, ai colori Pantone e all\'effetto desiderato.',
  },
  {
    q: 'I prodotti sono sostenibili e certificati?',
    a: 'Gran parte del catalogo è realizzata in RPET, bamboo, sughero o materiali riciclati, con certificazioni FSC, GOTS o OEKO-TEX. Su richiesta vi forniamo le certificazioni specifiche per ogni articolo.',
  },
  {
    q: 'Spedite in tutta Italia?',
    a: 'Sì, in tutta Italia. Su richiesta, anche nel resto d\'Europa. Stampa e personalizzazione vengono curate dal nostro team interno.',
  },
];
---

<BaseLayout
  title="2promo.it — Gadget aziendali personalizzati. Stampiamo su tutto."
  description="Gadget aziendali personalizzati B2B. 30.000+ articoli a catalogo, linea custom su misura da 10 pezzi. Dal 2014."
>
  <UrgencyBar />
  <Navbar activeRoute="home" />
  <Hero variant="home" />
  <Trust variant="marquee" />
  <Counters />
  <Categories />
  <CasiReali />
  <Showcase />
  <EscapeHatchCustom />
  <HowItWorks variant="standard" />
  <Faq items={faqItems} />
  <Certifications />
  <ContactForm id="preventivo" />
  <Footer />
</BaseLayout>
