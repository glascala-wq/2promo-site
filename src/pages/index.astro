---
import BaseLayout from '../layouts/BaseLayout.astro';
import UrgencyBar from '../components/UrgencyBar.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import Trust from '../components/Trust.astro';
import Counters from '../components/Counters.astro';
import Categories from '../components/Categories.astro';
import AllestimentiShowcase from '../components/AllestimentiShowcase.astro';
import EscapeHatchCustom from '../components/EscapeHatchCustom.astro';
import HowItWorks from '../components/HowItWorks.astro';
import Faq from '../components/Faq.astro';
import Certifications from '../components/Certifications.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';

// Server-rendered (non prerenderizzata) solo per permettere al middleware di
// intercettare le richieste su custom.2promo.it (dominio dismesso) e
// redirigerle — vedi src/middleware.ts. _routes.json esclude "/" dal Worker
// per qualsiasi pagina prerenderizzata, quindi è l'unico modo per farlo funzionare.
export const prerender = false;

const faqItems = [
  {
    q: 'Quali sono i tempi di consegna dei gadget personalizzati?',
    a: 'A partire da 2-3 giorni dalla conferma per gli ordini standard (il tempo esatto dipende da prodotto e quantità). 12-15 giorni per la linea custom. Su richiesta organizziamo consegne express per scadenze urgenti.',
    open: true,
  },
  {
    q: 'Posso vedere una bozza prima di pagare?',
    a: 'Nella grande maggioranza dei casi sì: bozza visiva inclusa nel preventivo, gratuita e senza impegno, per approvare prima di pagare. Per alcuni prodotti specifici, in base alla tecnica di produzione, la conferma visiva arriva in una fase successiva: quando succede ve lo segnaliamo già nel preventivo, così sapete fin da subito cosa aspettarvi.',
  },
  {
    q: 'Posso ordinare piccole quantità di gadget aziendali personalizzati?',
    a: 'Sì, anche un singolo pezzo come campione su molti articoli del catalogo standard. Sulla <a href="/custom" class="text-orange underline">Linea Custom</a> partiamo da 10 pezzi su misura. Per collezioni particolari definiamo insieme un lotto pilota personalizzato.',
  },
  {
    q: 'Quali tecniche di stampa usate per personalizzare i gadget?',
    a: 'Serigrafia, tampografia, transfer digitale, incisione laser, ricamo. Il nostro reparto tecnico vi consiglia la tecnica migliore in base al materiale, ai colori Pantone e all\'effetto desiderato. <a href="/tecniche-di-stampa-gadget-personalizzati" class="text-orange underline">Guida completa alle tecniche di stampa</a>.',
  },
  {
    q: 'I gadget aziendali sono sostenibili e certificati?',
    a: 'Gran parte del catalogo è realizzata in RPET, bamboo, sughero o materiali riciclati, con certificazioni FSC, GOTS o OEKO-TEX. Su richiesta vi forniamo le certificazioni specifiche per ogni articolo.',
  },
  {
    q: 'Spedite i gadget personalizzati in tutta Italia?',
    a: 'Sì, in tutta Italia. Su richiesta, anche nel resto d\'Europa. Stampa e personalizzazione vengono curate dal nostro team interno.',
  },
  {
    q: 'Fate anche allestimenti per uffici, eventi e fiere?',
    a: 'Sì: fondali, totem, banchetti, segnaletica, gazebo, bandiere, roll-up e banner, con lo stesso sistema modulare e la stessa cura nei materiali dei gadget. Utili in ufficio, in un punto vendita, durante un evento aziendale o in fiera: ovunque un\'azienda abbia bisogno di far risaltare logo o informazioni. Forniamo il materiale pronto da montare, non il servizio di installazione in loco. <a href="/allestimenti" class="text-orange underline">Scoprite la pagina dedicata agli allestimenti</a>.',
  },
];
---

<BaseLayout
  title="Gadget e Allestimenti Personalizzati: 30.000+ Articoli | 2promo.it"
  description="Gadget e allestimenti personalizzati: 30.000+ articoli promozionali, soluzioni per uffici, punti vendita, eventi e fiere, linea custom da 10 pezzi. Dal 2014. Richiedi un preventivo gratuito."
>
  <UrgencyBar />
  <Navbar activeRoute="home" />
  <Hero variant="home" />
  <Trust variant="marquee" />
  <Counters />
  <Categories />
  <AllestimentiShowcase />
  <EscapeHatchCustom />
  <HowItWorks variant="standard" />
  <Faq items={faqItems} />
  <Certifications />

  <!-- Sezione testuale indicizzabile: copre le query che i buyer B2B cercano davvero -->
  <section class="bg-cream pb-20 md:pb-24">
    <div class="max-w-4xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-6">
        <span class="eyebrow text-ink/70">chi siamo</span>
      </div>
      <h2 class="font-display-tight text-3xl md:text-4xl text-ink leading-tight mb-6">
        Gadget e allestimenti personalizzati per aziende, dal 2014.
      </h2>
      <div class="text-ink/70 leading-relaxed space-y-4 max-w-3xl">
        <p>
          2promo.it è il reparto gadget e allestimenti di <strong class="text-ink">JAS Srl</strong>, attiva dal 2014 nella fornitura di <strong class="text-ink">gadget personalizzati per aziende</strong>: penne, borracce, zaini, power bank, <a href="/welcome-kit-aziendali" class="text-orange underline">welcome kit per dipendenti</a> e <a href="/regali-aziendali-natale" class="text-orange underline">regali aziendali personalizzati</a>, tutti stampabili col vostro logo. Il catalogo copre oltre 30.000 articoli promozionali, dal singolo campione alle grandi commesse. Per progetti su misura (forme custom, Pantone esatto, merchandising aziendale multi-prodotto) lavoriamo con la <a href="/custom" class="text-orange underline">Linea Custom</a>, da 10 pezzi.
        </p>
        <p>
          Accanto al gadget ci occupiamo anche di <a href="/allestimenti" class="text-orange underline">allestimenti</a>: fondali, totem, banchetti, segnaletica, gazebo, bandiere, roll-up e banner, pensati per qualsiasi contesto in cui un'azienda debba far risaltare il proprio logo o le proprie informazioni, che sia un ufficio, un punto vendita, un evento aziendale o una fiera. Sistema modulare, con struttura solida e grafica curata gestite separatamente, pronto per essere montato in autonomia (forniamo il materiale, non il servizio di installazione in loco). Spedizioni in tutta Italia, su richiesta anche in Europa. Siamo membri <strong class="text-ink">ASSOPROM</strong>, l'associazione italiana dei produttori e distributori di articoli pubblicitari e promozionali.
        </p>
      </div>
    </div>
  </section>

  <ContactForm id="preventivo" />
  <Footer />
</BaseLayout>
