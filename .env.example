# 2promo-landing — variabili d'ambiente
# Copia in .env (gitignored) e compila con i valori reali.

# Brevo (CRM + email transazionali)
BREVO_API_KEY=
BREVO_LIST_ID_PREVENTIVO=17
BREVO_LIST_ID_CATALOGO=14
BREVO_LIST_ID_GOLF=21
BREVO_NOTIFICATION_EMAIL=info@2promo.it

# Analytics / Ads (PUBLIC_ = esposte al client)
PUBLIC_GA=
PUBLIC_GOOGLE_ADS_ID=
PUBLIC_META_PIXEL_ID=
# Conversione Google Ads dedicata al verticale golf — da valorizzare quando la campagna è creata (vedi TBD-REGISTRY.md)
PUBLIC_GOLF_ADS_CONVERSION_LABEL=

# Cloudflare Turnstile (anti-spam form, iter-10)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
